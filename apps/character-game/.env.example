CHATGAME_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
CHATGAME_PUBLIC_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
CHATGAME_OPENAI_API_KEY=local-dev-key
CHATGAME_CHAT_MODEL=chatgpt-web/auto
CHATGAME_IMAGE_MODEL=chatgpt-web/auto
CHATGAME_DB_PATH=.data/arcadia.sqlite
CHATGAME_IMAGE_DIR=.data/images

